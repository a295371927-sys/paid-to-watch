{
  "name": "paid-to-watch",
  "version": "0.2.0",
  "description": "伪装成右下角广告弹窗的本地视频摸鱼播放器",
  "main": "src/main/main.js",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0",
    "vitest": "^2.0.0"
  },
  "build": {
    "appId": "com.stevenliang.paidtowatch",
    "productName": "带薪看片",
    "files": ["src/**/*", "assets/**/*"],
    "win": { "target": "portable", "signAndEditExecutable": false }
  }
}
